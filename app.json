{
  "expo": {
    "name": "BütçeM",
    "slug": "BudgetApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-v2.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "budgetapp",
    "splash": {
      "image": "./assets/splash-v2.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.budgetapp.butcem"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon-v2.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.budgetapp.butcem"
    },
    "web": {
      "favicon": "./assets/favicon-v2.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ]
  }
}